  "query": "\n        UPDATE workspaces\n        SET name = COALESCE($2, name),\n            logo_url = COALESCE($3, logo_url),\n            settings = COALESCE($4, settings),\n            updated_at = NOW()\n        WHERE id = $1\n        RETURNING id, name, type as \"workspace_type: WorkspaceType\", owner_id, logo_url, \n                  settings, created_at, updated_at\n        ",
