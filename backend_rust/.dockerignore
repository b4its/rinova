# Rust build artifacts (can be 1-2GB)
target/
**/target/

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Environment files
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Documentation
*.md
!README.md

# Test files
# NOTE: the top-level `tests/` crate is a workspace member declared in
# Cargo.toml, so it MUST be present for cargo to resolve the workspace inside
# Docker. Do not ignore it. Only ignore stray per-service test artifacts.
**/*.test.rs
**/*.spec.rs

# Coverage
coverage/
.coverage/

# Temporary files
tmp/
temp/
*.log

# Docker files
docker-compose*.yml
Dockerfile*

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Kiro
.kiro/
