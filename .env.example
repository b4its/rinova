# Rinova Website Builder - Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
POSTGRES_USER=rinova
POSTGRES_PASSWORD=rinova_secret_change_in_production
POSTGRES_DB=rinova

# MongoDB Configuration
MONGO_USER=rinova
MONGO_PASSWORD=rinova_secret_change_in_production
MONGO_DB=rinova

# Redis Configuration
REDIS_PASSWORD=rinova_redis_secret_change_in_production

# JWT Configuration
JWT_SECRET=rinova_jwt_secret_key_change_in_production_min_32_chars

# Hyperledger Besu Configuration
BESU_PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63
OWNERSHIP_CONTRACT_ADDRESS=
AUDIT_CONTRACT_ADDRESS=

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SMTP Configuration (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# IPFS Configuration (optional)
IPFS_API_URL=http://ipfs:5001

# AWS S3 Configuration (for hosting)
HOSTING_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# API URLs
API_URL=http://localhost:8080
WS_URL=ws://localhost:8080

# Sentry (optional, for error tracking)
SENTRY_DSN=
